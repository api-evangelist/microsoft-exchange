{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ContactDeltaResponse",
  "title": "ContactDeltaResponse",
  "type": "object",
  "description": "Delta response for contacts",
  "properties": {
    "@odata.context": {
      "type": "string"
    },
