{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/EmailAddress",
  "title": "EmailAddress",
  "type": "object",
  "description": "The name and email address of a person",
  "properties": {
    "name": {
      "type": "string",
      "description": "The display name"
    },
    "address": {
      "type": "string",
      "format": "email",
      "description": "The email address"
    }
  }
}